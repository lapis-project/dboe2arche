<https://id.acdh.oeaw.ac.at/dboe-tei-xml> a acdh:TopCollection ;
    acdh:hasDescription """The data in this collection originates from a project conducted by a predecessor institution of the Austrian Centre for Digital Humanities. The collection contains scans of the Wiener Schaubühne, a cultural magazine published in Vienna from 1896 to 1901 as well as XML encoded full texts"""@en ;
    acdh:hasDescription """Die Daten in dieser Sammlung stammen aus einem Projekt, das von einer Vorgängereinrichtung des Austrian Centre for Digital Humanities durchgeführt wurde. Die Sammlung enthält Scans der Wiener Schaubühne, einer Kulturzeitschrift, die von 1896 bis 1901 in Wien veröffentlicht wurde, sowie XML-kodierte Volltexte."""@de ;
    acdh:hasCoverageStartDate "1900-01-01"^^xsd:date ;
    acdh:hasCoverageEndDate "2025-01-31"^^xsd:date ;
    acdh:hasTitle """DBO@TEI"""@de ;
    acdh:hasTitle """DBO@TEI"""@en ;
    acdh:hasLifeCycleStatus <https://vocabs.acdh.oeaw.ac.at/archelifecyclestatus/completed> ;
