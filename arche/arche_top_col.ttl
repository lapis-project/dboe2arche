<https://id.acdh.oeaw.ac.at/dboe-tei-xml> a acdh:TopCollection ;
    acdh:hasDescription """This is the TEI version of the Datenbank der Baierischen Dialekte in Österreich, being the digitized data source of the Wörterbuch der Baierischen Dialekte in Österreich (WBÖ). It was originally transcribed in TUSTEP and has been converted to TEI, serving as one of the building blocks of "LIÖ – Lexikographisches Informationssystem Österreich"."""@en ;
    acdh:hasDescription """Das ist die TEI-Version der Datenbank der Baierischen Dialekte in Österreich, die die digitalisierte Datenquelle des Wörterbuchs der Baierischen Dialekte in Österreich (WBÖ) darstellt. Sie wurde ursprünglich in TUSTEP transkribiert und in TEI konvertiert und dient als einer der Bausteine des "LIÖ – Lexikographisches Informationssystem Österreich"."""@de ;
    acdh:hasTemporalCoverage """ToDo"""@de ;
    acdh:hasCoverageStartDate "1900-01-01"^^xsd:date ;
    acdh:hasCoverageEndDate "2025-01-31"^^xsd:date ;
    acdh:hasTitle """DBO@TEI"""@de ;
    acdh:hasTitle """DBO@TEI"""@en ;
    acdh:hasUrl "https://wboe.lapis-online.at/db";
    acdh:hasAlternativeTitle """WBÖ-Belegdatenbank"""@de ;
    acdh:hasAlternativeTitle """WBÖ Database"""@en ;
    acdh:hasLifeCycleStatus <https://vocabs.acdh.oeaw.ac.at/archelifecyclestatus/active> ;
    acdh:hasCompleteness """ToDo: Erklären warum erst bei D begeonnen wird"""@de;
    acdh:hasAppliedMethodDescription """ToDo: Erkären wie die Daten (TEI/XML) erstellt wurden""";
    acdh:hasSubject "Dialektlexikographie"@de ;
    acdh:hasSubject "Dialect lexicography"@en ;
    acdh:hasLanguage <https://vocabs.acdh.oeaw.ac.at/iso6393/deu> ;
